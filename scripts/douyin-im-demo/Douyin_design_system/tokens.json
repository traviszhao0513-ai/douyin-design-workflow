{
  "$schema": "https://json.schemastore.org/design-tokens",
  "meta": {
    "name": "Douyin Delight UI Kit",
    "version": "1.0.0",
    "source": "https://www.figma.com/design/4clg3rdsyoyTbuZVVEMnUx"
  },

  "color": {
    "brand": {
      "primary":   { "$value": "#2B79FF", "$type": "color", "$description": "主品牌色 — Douyin 蓝" },
      "secondary": { "$value": "#FE2C55", "$type": "color", "$description": "品牌辅助色 — 抖音红" },
      "primaryHover":    { "$value": "#1465E0", "$type": "color" },
      "primaryActive":   { "$value": "#0F4FBA", "$type": "color" },
      "primaryDisabled": { "$value": "#A3C3FF", "$type": "color" },
      "primarySurface":  { "$value": "#EBF1FF", "$type": "color", "$description": "品牌浅色底面" }
    },

    "text": {
      "primary":   { "$value": "#161823", "$type": "color", "$description": "一级正文" },
      "secondary": { "$value": "#8A8B94", "$type": "color", "$description": "二级辅助文字" },
      "tertiary":  { "$value": "#C4C5CB", "$type": "color", "$description": "三级/禁用文字" },
      "inverse":   { "$value": "#FFFFFF", "$type": "color", "$description": "反色文字（深底）" },
      "link":      { "$value": "#2B79FF", "$type": "color" },
      "danger":    { "$value": "#FE2C55", "$type": "color" }
    },

    "background": {
      "page":      { "$value": "#F4F4F4", "$type": "color", "$description": "页面背景" },
      "surface":   { "$value": "#FFFFFF", "$type": "color", "$description": "卡片/组件背景" },
      "overlay":   { "$value": "rgba(22,24,35,0.60)", "$type": "color", "$description": "蒙层" },
      "subtle":    { "$value": "#FAFAFA", "$type": "color" }
    },

    "border": {
      "light":   { "$value": "#E3E3E4", "$type": "color", "$description": "轻量描边" },
      "medium":  { "$value": "#C4C5CB", "$type": "color" },
      "focused": { "$value": "#2B79FF", "$type": "color" }
    },

    "status": {
      "success":        { "$value": "#25C685", "$type": "color" },
      "successSurface": { "$value": "#E6F9F1", "$type": "color" },
      "warning":        { "$value": "#FF8800", "$type": "color" },
      "warningSurface": { "$value": "#FFF3E0", "$type": "color" },
      "error":          { "$value": "#FE2C55", "$type": "color" },
      "errorSurface":   { "$value": "#FFEBEE", "$type": "color" },
      "info":           { "$value": "#2B79FF", "$type": "color" },
      "infoSurface":    { "$value": "#EBF1FF", "$type": "color" }
    },

    "neutral": {
      "0":   { "$value": "#FFFFFF", "$type": "color" },
      "50":  { "$value": "#FAFAFA", "$type": "color" },
      "100": { "$value": "#F4F4F4", "$type": "color" },
      "200": { "$value": "#E3E3E4", "$type": "color" },
      "300": { "$value": "#C4C5CB", "$type": "color" },
      "400": { "$value": "#A5A6AF", "$type": "color" },
      "500": { "$value": "#8A8B94", "$type": "color" },
      "600": { "$value": "#6B6C76", "$type": "color" },
      "700": { "$value": "#4D4E58", "$type": "color" },
      "800": { "$value": "#2E2F3A", "$type": "color" },
      "900": { "$value": "#161823", "$type": "color" },
      "950": { "$value": "#0A0B12", "$type": "color" }
    }
  },

  "typography": {
    "fontFamily": {
      "sans":  { "$value": "\"PingFang SC\", \"SF Pro Display\", -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif", "$type": "fontFamily" },
      "mono":  { "$value": "\"SF Mono\", \"Cascadia Code\", Menlo, monospace", "$type": "fontFamily" }
    },
    "fontSize": {
      "xs":   { "$value": "10px", "$type": "dimension" },
      "sm":   { "$value": "12px", "$type": "dimension" },
      "base": { "$value": "14px", "$type": "dimension" },
      "md":   { "$value": "15px", "$type": "dimension" },
      "lg":   { "$value": "16px", "$type": "dimension" },
      "xl":   { "$value": "17px", "$type": "dimension" },
      "2xl":  { "$value": "18px", "$type": "dimension" },
      "3xl":  { "$value": "20px", "$type": "dimension" },
      "4xl":  { "$value": "22px", "$type": "dimension" },
      "5xl":  { "$value": "24px", "$type": "dimension" },
      "6xl":  { "$value": "28px", "$type": "dimension" },
      "7xl":  { "$value": "32px", "$type": "dimension" },
      "8xl":  { "$value": "36px", "$type": "dimension" }
    },
    "fontWeight": {
      "regular":   { "$value": "400", "$type": "fontWeight" },
      "medium":    { "$value": "500", "$type": "fontWeight" },
      "semibold":  { "$value": "600", "$type": "fontWeight" },
      "bold":      { "$value": "700", "$type": "fontWeight" }
    },
    "lineHeight": {
      "tight":   { "$value": "1.2", "$type": "number" },
      "snug":    { "$value": "1.375", "$type": "number" },
      "normal":  { "$value": "1.5", "$type": "number" },
      "relaxed": { "$value": "1.625", "$type": "number" }
    },
    "letterSpacing": {
      "tighter": { "$value": "-0.02em", "$type": "dimension" },
      "normal":  { "$value": "0em",     "$type": "dimension" },
      "wide":    { "$value": "0.02em",  "$type": "dimension" }
    }
  },

  "spacing": {
    "0":   { "$value": "0px",   "$type": "dimension" },
    "1":   { "$value": "4px",   "$type": "dimension" },
    "2":   { "$value": "8px",   "$type": "dimension" },
    "3":   { "$value": "12px",  "$type": "dimension" },
    "4":   { "$value": "16px",  "$type": "dimension" },
    "5":   { "$value": "20px",  "$type": "dimension" },
    "6":   { "$value": "24px",  "$type": "dimension" },
    "7":   { "$value": "28px",  "$type": "dimension" },
    "8":   { "$value": "32px",  "$type": "dimension" },
    "10":  { "$value": "40px",  "$type": "dimension" },
    "12":  { "$value": "48px",  "$type": "dimension" },
    "14":  { "$value": "56px",  "$type": "dimension" },
    "16":  { "$value": "64px",  "$type": "dimension" }
  },

  "borderRadius": {
    "none": { "$value": "0px",    "$type": "dimension" },
    "xs":   { "$value": "4px",    "$type": "dimension" },
    "sm":   { "$value": "8px",    "$type": "dimension" },
    "md":   { "$value": "12px",   "$type": "dimension" },
    "lg":   { "$value": "16px",   "$type": "dimension" },
    "xl":   { "$value": "20px",   "$type": "dimension" },
    "2xl":  { "$value": "24px",   "$type": "dimension" },
    "full": { "$value": "9999px", "$type": "dimension", "$description": "胶囊/圆形按钮" }
  },

  "shadow": {
    "sm":  { "$value": "0 1px 4px 0 rgba(22,24,35,0.08)",                            "$type": "shadow" },
    "md":  { "$value": "0 4px 12px 0 rgba(22,24,35,0.12)",                           "$type": "shadow" },
    "lg":  { "$value": "0 8px 24px 0 rgba(22,24,35,0.16)",                           "$type": "shadow" },
    "xl":  { "$value": "0 16px 40px 0 rgba(22,24,35,0.20)",                          "$type": "shadow" },
    "focus":{ "$value": "0 0 0 3px rgba(43,121,255,0.24)",                           "$type": "shadow" }
  },

  "motion": {
    "duration": {
      "fast":   { "$value": "100ms", "$type": "duration" },
      "normal": { "$value": "200ms", "$type": "duration" },
      "slow":   { "$value": "300ms", "$type": "duration" }
    },
    "easing": {
      "standard": { "$value": "cubic-bezier(0.4, 0, 0.2, 1)", "$type": "cubicBezier" },
      "enter":    { "$value": "cubic-bezier(0, 0, 0.2, 1)",   "$type": "cubicBezier" },
      "exit":     { "$value": "cubic-bezier(0.4, 0, 1, 1)",   "$type": "cubicBezier" }
    }
  },

  "zIndex": {
    "base":    { "$value": "0",    "$type": "number" },
    "raised":  { "$value": "10",   "$type": "number" },
    "dropdown":{ "$value": "100",  "$type": "number" },
    "sticky":  { "$value": "200",  "$type": "number" },
    "overlay": { "$value": "300",  "$type": "number" },
    "modal":   { "$value": "400",  "$type": "number" },
    "toast":   { "$value": "500",  "$type": "number" }
  }
}
